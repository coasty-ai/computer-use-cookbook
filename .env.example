# Coasty Computer Use API configuration
# Copy this file to .env and fill in your values. NEVER commit .env.

# Your API key from https://coasty.ai/developers/keys
# Use a sandbox key (sk-coasty-test-...) for development — it never bills.
COASTY_API_KEY=sk-coasty-test-your-key-here

# Optional: override the API base URL (e.g. the local mock server).
# Defaults to https://coasty.ai/v1 when unset.
# COASTY_BASE_URL=http://127.0.0.1:8787/v1

# Optional: set to 1 to allow examples to make live billable calls.
# Examples that spend money refuse to run without this (or --confirm).
# COASTY_CONFIRM_SPEND=0

# Optional: set to 1 to enable live smoke tests (sandbox keys only).
# COASTY_RUN_LIVE=0

# Optional: a machine id for run/workflow/machine examples.
# With a test key, examples can provision a free mch_test_* sandbox VM instead.
# COASTY_MACHINE_ID=
